{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "functions": {
    "api/incoming-email.ts": { "maxDuration": 60 },
    "api/call-screening.ts": { "maxDuration": 60 },
    "api/help-desk.ts": { "maxDuration": 60 },
    "api/voicemail-greeting.ts": { "maxDuration": 60 },
    "api/voicemail-result.ts": { "maxDuration": 60 },
    "api/outbound-messages.ts": { "maxDuration": 30 },
    "api/twilio-recording.ts": { "maxDuration": 60 },
    "api/platform-tools.ts": { "maxDuration": 60 },
    "api/payment-requests.ts": { "maxDuration": 60 },
    "api/sandbox-simulator.ts": { "maxDuration": 60 },
    "api/privacy.ts": { "maxDuration": 30 },
    "api/terms.ts": { "maxDuration": 30 },
    "api/sms.ts": { "maxDuration": 30 },
    "api/sms-cta-guidance.ts": { "maxDuration": 30 },
    "api/legal-health.ts": { "maxDuration": 10 },
    "api/robots.ts": { "maxDuration": 10 },
    "api/sitemap.ts": { "maxDuration": 10 },
    "api/sms-opt-in-consent-form-pdf.ts": { "maxDuration": 15 },
    "api/sms-opt-in-consent-submit.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/api/helcim-js-return",
      "destination": "/api/platform-tools?__route=helcim-js-return"
    },
    {
      "source": "/api/notify-admin-verified-signup",
      "destination": "/api/platform-tools?__route=notify-admin-verified-signup"
    },
    {
      "source": "/api/notify-admin-new-signup",
      "destination": "/api/platform-tools?__route=notify-admin-new-signup"
    },
    {
      "source": "/api/notify-admin-trial-signup",
      "destination": "/api/platform-tools?__route=notify-admin-trial-signup"
    },
    {
      "source": "/api/send-onboarding-welcome",
      "destination": "/api/platform-tools?__route=send-onboarding-welcome"
    },
    {
      "source": "/api/notify-admin-support-ticket",
      "destination": "/api/platform-tools?__route=notify-admin-support-ticket"
    },
    {
      "source": "/api/notify-client-sms-disclosure",
      "destination": "/api/platform-tools?__route=notify-client-sms-disclosure"
    },
    {
      "source": "/api/billing-portal-config",
      "destination": "/api/platform-tools?__route=billing-portal-config"
    },
    {
      "source": "/api/payment-collection-webhook",
      "destination": "/api/payment-requests?__action=webhook"
    },
    { "source": "/api/help-desk-voice", "destination": "/api/help-desk?__route=voice" },
    { "source": "/api/help-desk-greeting-save", "destination": "/api/help-desk?__route=greeting-save" },
    {
      "source": "/api/help-desk-trouble-ticket-result",
      "has": [{ "type": "query", "key": "phase", "value": "transcribe" }],
      "destination": "/api/help-desk?__route=trouble-ticket-result&phase=transcribe"
    },
    {
      "source": "/api/help-desk-trouble-ticket-result",
      "destination": "/api/help-desk?__route=trouble-ticket-result&phase=record"
    },
    { "source": "/reset-password", "destination": "/index.html" },
    { "source": "/api/send-email", "destination": "/api/outbound-messages?__channel=email" },
    { "source": "/api/send-sms", "destination": "/api/outbound-messages?__channel=sms" },
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/privacy",
      "destination": "/api/privacy"
    },
    {
      "source": "/privacy/",
      "destination": "/api/privacy"
    },
    {
      "source": "/terms",
      "destination": "/api/terms"
    },
    {
      "source": "/terms/",
      "destination": "/api/terms"
    },
    {
      "source": "/sms-consent",
      "destination": "/api/sms"
    },
    {
      "source": "/sms-consent/",
      "destination": "/api/sms"
    },
    {
      "source": "/sms",
      "destination": "/api/sms"
    },
    {
      "source": "/sms/",
      "destination": "/api/sms"
    },
    {
      "source": "/sms-cta/consent-form.pdf",
      "destination": "/api/sms-opt-in-consent-form-pdf"
    },
    {
      "source": "/sms-cta/submit",
      "destination": "/sms-cta-submit.html"
    },
    {
      "source": "/sms-cta/submit/",
      "destination": "/sms-cta-submit.html"
    },
    {
      "source": "/sms-cta",
      "destination": "/api/sms-cta-guidance"
    },
    {
      "source": "/sms-cta/",
      "destination": "/api/sms-cta-guidance"
    },
    {
      "source": "/sms-cts",
      "destination": "/api/sms-cta-guidance"
    },
    {
      "source": "/sms-cts/",
      "destination": "/api/sms-cta-guidance"
    },
    {
      "source": "/account-deletion",
      "destination": "/account-deletion.html"
    },
    {
      "source": "/account-deletion/",
      "destination": "/account-deletion.html"
    },
    { "source": "/about", "destination": "/" },
    { "source": "/pricing", "destination": "/" },
    { "source": "/embed/lead/:path*", "destination": "/index.html" }
  ]
}
