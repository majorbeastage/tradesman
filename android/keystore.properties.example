# Copy to keystore.properties (gitignored). Put your .jks in android/ (also gitignored).
# Create keystore once: keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile = the .jks binary ONLY — never keystore.properties (wrong file → "toDerInputStream rejects tag type 35").
# Android Studio: Build → Generate Signed App Bundle/APK remembers a keystore path in .idea/workspace.xml — that path must be the .jks, not keystore.properties.
# Debug: from android/, run: .\gradlew.bat :app:bundleRelease -PtradesmanPrintKeystore --no-daemon
#   → Build log prints the exact .jks path Gradle uses.
storeFile=upload-keystore.jks
storePassword=your-store-password
keyAlias=upload
keyPassword=your-key-password
