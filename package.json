{
  "name": "tradesman",
  "private": true,
  "version": "2.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/align-android-agp.cjs",
    "dev": "vite",
    "dev:start": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile:sync": "npm run build && npx cap sync && node scripts/align-android-agp.cjs",
    "mobile:build:android": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android.ps1",
    "mobile:build:all": "npm run mobile:sync",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "legal:static-html": "node scripts/generate-static-legal-html.mjs",
    "legal:sync-ssr": "node scripts/sync-legal-pages-ssr.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/functions": "^3.4.4",
    "capacitor-native-settings": "^8.1.0",
    "docx": "^9.6.1",
    "leaflet": "^1.9.4",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.10.0",
    "svix": "^1.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.20",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "supabase": "^2.84.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.4.11"
  }
}
